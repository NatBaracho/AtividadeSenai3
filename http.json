// Request
POST /api/v1/playlist HTTP/1.1
Host: localhost:5000
Content-Type: application/json
Authorization: Bearer token123

{
  "nomePlaylist": "Nirvana",
  "publica": true,
  "usuario_id": 1
}

// Responses
HTTP/1.1 201 Created
Content-Type: application/json

{
  "mensagem": "Playlist criada com sucesso!",
  "playlistId": 5
}

HTTP/1.1 400 Bad Request
Content-Type: application/json

{
  "erro": "Campos obrigatórios faltando"
}

HTTP/1.1 401 Unauthorized
Content-Type: application/json

{
  "erro": "Token de autenticação inválido ou ausente"
}

HTTP/1.1 500 Internal Server Error
Content-Type: application/json

{
  "erro": "Erro ao criar playlist"
}
/* Lista Playlists
request
*/

GET /api/v1/playlists HTTP/1.1
Host: localhost:5000
Authorization: Bearer token123


